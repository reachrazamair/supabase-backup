# ---------------------------------------------------------------------------
# Supabase backup tool + dashboard configuration.
#
# Copy this file to ".env" (same folder) and fill in the real values:
#     cp .env.example .env
#
# The .env file holds all secrets and is git-ignored. Never commit it.
# ---------------------------------------------------------------------------

# ===========================================================================
# Database (required) — used by backup.py
# ===========================================================================
# Full Postgres connection string that pg_dump will use.
# In Supabase: Project Settings -> Database -> Connection string -> URI.
# URL-encode special chars in the password. Example shape:
#   postgresql://postgres:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=

# ===========================================================================
# Azure Blob Storage (required) — used by backup.py and the dashboard
# ===========================================================================
# Connection string for the storage account.
# Azure Portal -> Storage account -> Access keys -> Connection string.
AZURE_STORAGE_CONNECTION_STRING=

# Name of the blob container backups are uploaded to. Created automatically
# if it does not already exist. Must be lowercase.
AZURE_CONTAINER_NAME=supabase-backups

# ===========================================================================
# Email alerts (SMTP) — used by notify.py
# ===========================================================================
# A failed email never crashes a backup; if these are missing, alerts are
# simply skipped (with a warning on stderr).
SMTP_HOST=              # e.g. smtp.gmail.com or smtp.sendgrid.net
SMTP_PORT=587           # 587 = STARTTLS (common), 465 = implicit TLS/SSL
SMTP_USER=              # SMTP username (optional if your relay allows it)
SMTP_PASSWORD=          # SMTP password / app password / API key
ALERT_FROM=             # From address, e.g. backups@yourdomain.com
ALERT_TO=               # Recipient(s), comma-separated for more than one

# Send a short "backup OK" email on success too? true / false.
# Failures are always emailed regardless of this flag.
NOTIFY_ON_SUCCESS=false

# ===========================================================================
# Dashboard (required to run app.py) — used by app.py
# ===========================================================================
# Login credentials for the web dashboard. The app refuses to start if unset.
PANEL_USER=admin
PANEL_PASSWORD=         # choose a strong password

# Secret key used to sign session cookies. MUST be set and kept private.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# ===========================================================================
# Tuning (optional, sensible defaults shown)
# ===========================================================================
# A finished gzip smaller than this many bytes is treated as a failed backup
# (catches empty/truncated dumps). Default 1024 (1 KB).
MIN_BACKUP_BYTES=1024

# Maximum seconds pg_dump may run before it is killed and the run fails.
# Guards against a hung database blocking the job forever. Default 3600 (1 hour);
# raise it for very large databases that legitimately take longer to dump.
PG_DUMP_TIMEOUT=3600

# Delete blobs in the container older than this many days. Default 90.
# Values below 7 (and 0/negative/invalid) are clamped up to a safe floor of 7.
RETENTION_DAYS=90

# How many of the most recent backup files to keep on LOCAL disk after a
# successful upload. Default 1. Set 0 to keep none locally (Azure only).
BACKUP_KEEP_LOCAL=1

# ===========================================================================
# Heartbeat / dead-man's switch (optional) — used by backup.py
# ===========================================================================
# If set, backup.py sends a simple HTTP GET to this URL ONLY after a fully
# successful backup + upload. An external monitor (e.g. https://healthchecks.io)
# can then alert you if the expected ping stops arriving — i.e. if backups
# silently stop running at all. Leave blank to disable.
HEARTBEAT_URL=
