# Secrets — never commit the real environment file.
.env

# Backup artifacts, run log, history database, and run lock.
*.sql.gz
backups.log
backups.db
backup.lock

# Python virtual environment.
venv/
.venv/

# Python bytecode caches.
__pycache__/
*.pyc

# Process output logs (dashboard / cron runtime output).
dashboard.out
cron.out

# Local editor/agent settings.
.claude/
