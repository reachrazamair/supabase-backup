# Secrets — never commit the real environment file or any copy of it.
.env
.env.*

# Backup artifacts, run log, history database, and run locks.
*.sql.gz
*.tar.gz
backups.log
backups.db
*.lock

# Python virtual environment.
venv/
.venv/

# Python bytecode caches.
__pycache__/
*.pyc

# Process output logs (dashboard / cron runtime output).
dashboard.out
cron.out

# Local editor/agent settings.
.claude/
